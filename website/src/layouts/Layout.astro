---
interface Props {
	title: string;
	lang?: 'en' | 'ja';
	isDocs?: boolean;
}

import LanguageToggle from '../components/LanguageToggle.astro';

const { title, lang = 'en', isDocs = false } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Amulet - Hardware-Bound, Zero-Trace Secret Manager for developers and AI assistants." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0" />
		<meta name="theme-color" content="#0f172a" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/logo.jpg" />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:title" content={`${title} | AMULET`} />
		<meta property="og:description" content="Hardware-Bound, Zero-Trace Secret Manager for developers and AI assistants." />
		<meta property="og:image" content="/logo.jpg" />
		<title>{title} | AMULET</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Outfit:wght@400;600;700;900&family=Inter:wght@400;600&display=swap" rel="stylesheet">
	</head>
	<body>
		<header class="header">
			<nav class="nav">
				<div class="container nav-content">
					<a href={lang === 'ja' ? '/ja' : '/'} class="nav-logo">
						<img src="/logo-icon.png" alt="Amulet Logo" class="nav-logo-img" />
						<span class="logo-text">AMULET</span>
					</a>
					
					<!-- Desktop Links -->
					<div class="nav-links desktop-only">
						<a href={lang === 'ja' ? "/ja/concepts" : "/concepts"} class="nav-link">Docs</a>
						<a href="https://github.com/tsukasa-art/amulet" class="nav-link">GitHub</a>
						<LanguageToggle />
					</div>

					<!-- Mobile Menu Button -->
					<button class="mobile-menu-btn mobile-only" aria-label="Menu">
						<span class="bar"></span>
						<span class="bar"></span>
						<span class="bar"></span>
					</button>
				</div>

				<!-- Mobile Side Panel (Merged if Docs) -->
				<div class="mobile-side-panel mobile-only" id="globalMobilePanel">
					<div class="panel-header">
						<span class="panel-title">{isDocs ? (lang === 'ja' ? 'ドキュメント' : 'Docs') : 'Menu'}</span>
						<button class="panel-close-btn" aria-label="Close">&times;</button>
					</div>
					<div class="panel-content">
						{isDocs && <div id="docs-mobile-nav-target"></div>}
						
						<div class="panel-section">
							<span class="section-label">Navigation</span>
							<a href={lang === 'ja' ? '/ja/concepts' : '/concepts'} class="panel-link">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
								Docs
							</a>
							<a href="https://github.com/tsukasa-art/amulet" class="panel-link">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
								GitHub
							</a>
						</div>
						<div class="panel-section">
							<span class="section-label">Language Switch</span>
							<div class="panel-lang-switch">
								<a href="/" class={lang === 'en' ? 'active' : ''}>English</a>
								<a href="/ja" class={lang === 'ja' ? 'active' : ''}>日本語</a>
							</div>
						</div>
					</div>
				</div>
				<div class="panel-backdrop mobile-only" id="panelBackdrop"></div>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="footer">
			<div class="container">
				<p>&copy; {new Date().getFullYear()} Amulet Secret Manager. All rights reserved.</p>
			</div>
		</footer>

		<script is:inline>
			function setupMobilePanel() {
				const openBtn = document.querySelector('.mobile-menu-btn');
				const closeBtn = document.querySelector('.panel-close-btn');
				const panel = document.getElementById('globalMobilePanel');
				const backdrop = document.getElementById('panelBackdrop');
				const body = document.body;

				if (!openBtn || !panel || !backdrop) return;

				function openPanel() {
					panel.classList.add('active');
					backdrop.classList.add('active');
					body.classList.add('no-scroll');

					const docsSidebar = document.getElementById('docsSidebarNav');
					const mobileTarget = document.getElementById('docs-mobile-nav-target');
					if (docsSidebar && mobileTarget) {
						mobileTarget.innerHTML = '';
						mobileTarget.appendChild(docsSidebar.cloneNode(true));
					}
				}

				function closePanel() {
					panel.classList.remove('active');
					backdrop.classList.remove('active');
					body.classList.remove('no-scroll');
				}

				openBtn.addEventListener('click', openPanel);
				closeBtn?.addEventListener('click', closePanel);
				backdrop.addEventListener('click', closePanel);

				panel.addEventListener('click', (e) => {
					if (e.target.tagName === 'A') closePanel();
				});
			}

			setupMobilePanel();
			document.addEventListener('astro:page-load', setupMobilePanel);
		</script>
		<script src="/tap-copy.js" defer></script>
	</body>
</html>

<style is:global>
	@import "../styles/global.css";

	.header {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 1000;
		background: rgba(15, 23, 42, 0.85);
		backdrop-filter: blur(20px);
		border-bottom: 1px solid var(--glass-border);
	}

	.nav-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		height: 5rem;
	}

	.nav-logo {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-weight: 900;
		font-size: 1.4rem;
		letter-spacing: 0.1em;
		color: var(--color-cream);
	}

	.nav-logo-img { height: 38px; width: auto; object-fit: contain; transform: translateY(-3px); }

	.nav-links { display: flex; align-items: center; gap: 2.5rem; }
	.nav-link { font-size: 1rem; font-weight: 600; color: var(--color-text-muted); }
	.nav-link:hover { color: var(--color-gold); }

	.nav-link:hover { color: var(--color-gold); }

	/* Mobile Menu Button */
	.mobile-menu-btn {
		display: none;
		flex-direction: column;
		gap: 6px;
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 10px;
		min-width: 44px;
		min-height: 44px;
		align-items: center;
		justify-content: center;
		touch-action: manipulation;
	}

	.mobile-menu-btn .bar { width: 24px; height: 2px; background-color: var(--color-cream); border-radius: 2px; }

	/* Mobile Side Panel */
	.mobile-side-panel {
		position: fixed;
		top: 0;
		right: 0;
		width: 88%; 
		max-width: 340px;
		height: 100dvh; /* 動的ビューポートに対応 */
		background: rgba(15, 23, 42, 0.98);
		backdrop-filter: blur(20px); /* プレミアムな透け感 */
		z-index: 1100;
		transform: translateX(100%);
		transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
		display: flex;
		flex-direction: column;
		box-shadow: -20px 0 50px rgba(0, 0, 0, 0.5);
		overflow-y: auto;
		padding-bottom: env(safe-area-inset-bottom); /* iPhoneのバー対策 */
	}

	.mobile-side-panel.active { transform: translateX(0); }

	.panel-header {
		padding: 2rem 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.panel-title { font-weight: 900; font-size: 1.4rem; color: var(--color-gold); }
	.panel-close-btn { 
		background: transparent;
		border: none;
		color: var(--color-text-muted);
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.5rem;
		cursor: pointer;
		opacity: 0.7;
		transition: opacity 0.2s;
	}
	.panel-close-btn:hover { opacity: 1; }

	.panel-content { padding: 2.5rem 1.5rem; display: flex; flex-direction: column; gap: 4rem; }
	.panel-section { display: flex; flex-direction: column; gap: 1.5rem; }
	.section-label { font-size: 0.85rem; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.15em; }
	
	.panel-link {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--color-cream);
		padding: 0.75rem 0;
	}

	/* クローンされたドキュメント目次用のスタイル */
	#docs-mobile-nav-target nav { display: flex; flex-direction: column; gap: 2.5rem; }
	#docs-mobile-nav-target h4 { font-size: 0.85rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
	#docs-mobile-nav-target ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
	#docs-mobile-nav-target a { 
		display: block; 
		font-size: 1.15rem; 
		color: #cbd5e1; 
		padding: 0.85rem 0.5rem; 
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.03);
	}
	#docs-mobile-nav-target a.active { color: var(--color-gold); background: rgba(197, 160, 89, 0.1); font-weight: 700; }

	.panel-lang-switch { display: flex; flex-direction: column; gap: 1.5rem; }
	.panel-lang-switch a { font-size: 1.25rem; color: #cbd5e1; font-weight: 600; padding: 0.5rem 0; }
	.panel-lang-switch a.active { color: var(--color-gold); }

	.panel-backdrop {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100vh;
		background: rgba(0, 0, 0, 0.6);
		z-index: 1050;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.3s ease;
		backdrop-filter: blur(4px);
	}

	.panel-backdrop.active { opacity: 1; pointer-events: auto; }

	.no-scroll { overflow: hidden; }

	@media (max-width: 768px) {
		.desktop-only { display: none; }
		.mobile-menu-btn { display: flex; }
	}

	.footer {
		padding: 4rem 0;
		text-align: center;
		color: var(--color-text-muted);
		font-size: 0.9rem;
		border-top: 1px solid var(--glass-border);
	}
</style>
