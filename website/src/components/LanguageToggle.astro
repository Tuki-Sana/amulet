---
const pathname = Astro.url.pathname;
// 末尾のスラッシュを正規化して判定を安定させる
const normalizedPath = pathname.endsWith('/') && pathname !== '/' ? pathname.slice(0, -1) : pathname;
const isJa = normalizedPath === '/ja' || normalizedPath.startsWith('/ja/');

// 言語変換ロジック
let enHref, jaHref;
if (isJa) {
  enHref = normalizedPath.replace(/^\/ja/, '') || '/';
  jaHref = normalizedPath;
} else {
  enHref = normalizedPath;
  jaHref = normalizedPath === '/' ? '/ja' : '/ja' + normalizedPath;
}
---

<div class="lang-toggle">
  <a href={enHref} class:list={['lang-btn', { active: !isJa }]} aria-label="English">EN</a>
  <span class="sep">/</span>
  <a href={jaHref} class:list={['lang-btn', { active: isJa }]} aria-label="日本語">JA</a>
</div>

<style>
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    padding: 0.35rem 0.75rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    white-space: nowrap;
  }

  .lang-toggle:hover {
    border-color: rgba(197, 160, 89, 0.3);
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .lang-btn {
    color: #64748b; /* var(--color-text-muted) 相当 */
    text-decoration: none !important;
    transition: all 0.2s ease;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    -webkit-tap-highlight-color: transparent;
  }

  .lang-btn.active {
    color: #c5a059; /* var(--color-gold) 相当 */
    text-shadow: 0 0 12px rgba(197, 160, 89, 0.4);
  }

  .lang-btn:hover:not(.active) {
    color: #fcf9f2; /* var(--color-cream) 相当 */
  }

  .sep {
    color: rgba(255, 255, 255, 0.3); /* 少し明るくして可読性を確保 */
    user-select: none;
    font-size: 0.75rem;
    font-weight: 400;
  }

  /* Starlightのヘッダー内での微調整 */
  :global(.sl-header .lang-toggle) {
    margin-right: 0.5rem;
  }

  @media (max-width: 768px) {
    .lang-toggle {
      padding: 0.4rem 0.8rem;
    }
    .lang-btn {
      min-height: 32px; /* モバイルでのタップ領域確保 */
    }
  }
</style>
