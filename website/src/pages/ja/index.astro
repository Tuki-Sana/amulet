---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="ハードウェア紐付け型、痕跡を残さない秘密情報マネージャー" lang="ja">
	<section class="hero">
		<div class="container hero-content fade-in">
			<div class="logo-container">
				<img src="/logo.jpg" alt="Amulet Logo" class="hero-logo" />
				<div class="logo-glow"></div>
			</div>
			<h1 class="hero-title">
				<span class="line">AIや不注意による</span>
				<span class="line">秘密情報の流出を防ぐ</span>
			</h1>
			<p class="hero-subtitle">
				Amuletは、個人開発者やAI支援開発のために設計された、<br class="desktop-only" />
				ハードウェア紐付け型のシークレットマネージャーです。<br class="desktop-only" />
				もう .env ファイルは必要ありません。誤ったコミットも、AIによる盗み見も構造的に防ぎます。
			</p>
			<div class="hero-actions">
				<a href="/ja/concepts" class="btn btn-primary">使ってみる</a>
				<a href="https://github.com/tsukasa-art/amulet" class="btn btn-outline">GitHubを見る</a>
			</div>
		</div>
	</section>

	<section class="how-it-works container">
		<h2 class="section-title">導入はわずか3ステップ</h2>
		<div class="stepper-v2">
			<!-- Step 1: Install -->
			<div class="step-card-v2">
				<div class="step-header-v2">
					<span class="step-num-v2">01</span>
					<h3>Install <small>(インストール)</small></h3>
				</div>
				<div class="step-body-v2">
					<p>お使いの環境に合わせて、以下のコマンドでCLIをインストールします。</p>
					
					<div class="tab-terminal">
						<div class="tab-header">
							<button class="tab-btn active" data-tab="mac">macOS</button>
							<button class="tab-btn" data-tab="win">Windows</button>
							<button class="tab-btn" data-tab="linux">Linux / Other</button>
						</div>
						<div class="tab-content active" id="tab-mac">
							<div class="mini-terminal">
								<div class="mt-body"><span class="mt-prompt">$</span> <code>brew tap tsukasa-art/amulet && brew install amulet</code></div>
							</div>
						</div>
						<div class="tab-content" id="tab-win">
							<div class="mini-terminal">
								<div class="mt-body"><span class="mt-prompt">PS></span> <code>scoop bucket add amulet https://github.com/tsukasa-art/scoop-amulet.git && scoop install amulet</code></div>
							</div>
						</div>
						<div class="tab-content" id="tab-linux">
							<div class="mini-terminal">
								<div class="mt-body"><span class="mt-prompt">$</span> <code>curl -fsSL https://amulet.pages.dev/install.sh | sh</code></div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Step 2: Seal -->
			<div class="step-card-v2">
				<div class="step-header-v2">
					<span class="step-num-v2">02</span>
					<h3>Seal <small>(暗号化して保存)</small></h3>
				</div>
				<div class="step-body-v2">
					<p>APIキーなどの秘密情報を、マシン識別子に紐付けて安全に封印します。</p>
					
					<div class="tab-terminal">
						<div class="tab-header">
							<button class="tab-btn active" data-tab="mac-seal">macOS / Linux</button>
							<button class="tab-btn" data-tab="win-seal">Windows (PS)</button>
						</div>
						<div class="tab-content active" id="tab-mac-seal">
							<div class="mini-terminal">
								<div class="mt-body"><span class="mt-prompt">$</span> <code>echo -n "secret" | amulet seal OPENAI_KEY</code></div>
							</div>
						</div>
						<div class="tab-content" id="tab-win-seal">
							<div class="mini-terminal">
								<div class="mt-body"><span class="mt-prompt">PS></span> <code>"secret" | amulet seal OPENAI_KEY</code></div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Step 3: Use -->
			<div class="step-card-v2">
				<div class="step-header-v2">
					<span class="step-num-v2">03</span>
					<h3>Use <small>(コードから利用)</small></h3>
				</div>
				<div class="step-body-v2">
					<p>SDKやCLIを通じて秘密情報を呼び出します。平文はディスクに残りません。</p>

					<div class="tab-terminal">
						<div class="tab-header">
							<button class="tab-btn active" data-tab="mac-use">macOS / Linux</button>
							<button class="tab-btn" data-tab="win-use">Windows</button>
						</div>
						<div class="tab-content active" id="tab-mac-use">
							<div class="mini-terminal">
								<div class="mt-body"><span class="mt-prompt">$</span> <code>amulet unseal OPENAI_KEY</code></div>
							</div>
						</div>
						<div class="tab-content" id="tab-win-use">
							<div class="mini-terminal">
								<div class="mt-body"><span class="mt-prompt">PS></span> <code>amulet unseal OPENAI_KEY</code></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="features container">
		<div class="grid">
			<div class="feature-card">
				<div class="feature-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
				</div>
				<h3>ハードウェア紐付け</h3>
				<p>秘密情報はOSのマシン識別子に紐付けられ、封印したそのマシンでしか復号できません。</p>
			</div>
			<div class="feature-card">
				<div class="feature-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"/><path d="M12 12.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z"/><path d="M12 7v1"/><path d="M12 16v1"/><path d="M16 12h-1"/><path d="M9 12H8"/></svg>
				</div>
				<h3>AIセーフ設計</h3>
				<p>標準入力経由で値を渡すことで、AIエージェントによるコマンド引数の盗み見を構造的に防ぎます。</p>
			</div>
			<div class="feature-card">
				<div class="feature-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><path d="M4 12c-1.1 0-2-.9-2-2V7c0-1.1.9-2 2-2h16c1.1 0 2 .9 2 2v3c0 1.1-.9 2-2 2"/><path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7"/><path d="M9 17h6"/></svg>
				</div>
				<h3>ゼロ・トレース</h3>
				<p>サーバー不要、ローカル完結。外部ネットワークへの依存を排除し、完全なプライバシーを確保します。</p>
			</div>
		</div>
	</section>

	<section class="code-preview container">
		<div class="terminal">
			<div class="terminal-header">
				<div class="dot red"></div>
				<div class="dot yellow"></div>
				<div class="dot green"></div>
				<span class="terminal-title">bash</span>
			</div>
			<div class="terminal-body">
				<div class="line"><span class="cmd"># 秘密情報を保存する</span></div>
				<div class="line"><span class="prompt">$</span> <span class="cmd">echo -n "sk-..." | amulet seal OPENAI_KEY --file secrets.vault</span></div>
				<div class="line"><span class="out">Passphrase: ***********</span></div>
				<div class="line"></div>
				<div class="line"><span class="cmd"># コード内で使用する (Node.js等)</span></div>
				<div class="line"><span class="prompt">$</span> <span class="cmd">amulet unseal OPENAI_KEY --file secrets.vault</span></div>
			</div>
		</div>
	</section>
</Layout>

<script is:inline>
	function setupTabs() {
		const tabs = document.querySelectorAll('.tab-btn');
		
		tabs.forEach(tab => {
			tab.addEventListener('click', (e) => {
				e.preventDefault();
				const target = tab.getAttribute('data-tab');
				const container = tab.closest('.tab-terminal');
				if (!container) return;
				
				// すべてのタブから active を除去
				container.querySelectorAll('.tab-btn').forEach(t => t.classList.remove('active'));
				container.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
				
				// 選択されたタブを active に
				tab.classList.add('active');
				const content = document.getElementById(`tab-${target}`);
				if (content) {
					content.classList.add('active');
				}
			});
		});
	}

	// ページ読み込み時
	setupTabs();
	// Astro のページ遷移時 (View Transitions対応)
	document.addEventListener('astro:page-load', setupTabs);
</script>

<style>
	.hero {
		padding: 8rem 0 5rem;
		text-align: center;
		position: relative;
	}

	.logo-container {
		position: relative;
		display: inline-block;
		margin-bottom: 3rem;
	}

	.hero-logo {
		width: 440px;
		max-width: 85vw;
		height: auto;
		border-radius: 16px;
		position: relative;
		z-index: 2;
		box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
		border: 1px solid var(--glass-border);
	}

	.logo-glow {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 110%;
		height: 110%;
		background: radial-gradient(circle, var(--color-gold) 0%, transparent 70%);
		opacity: 0.15;
		filter: blur(40px);
		z-index: 1;
	}

	.hero-title {
		font-size: clamp(2rem, 8vw, 3.5rem);
		line-height: 1.3;
		margin-bottom: 2.5rem;
		font-family: 'Outfit', sans-serif;
		background: linear-gradient(to bottom, var(--color-cream), #cbd5e1);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		max-width: 900px;
		margin-left: auto;
		margin-right: auto;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.hero-title .line {
		display: block;
	}

	.hero-subtitle {
		font-size: 1.2rem;
		color: var(--color-text-muted);
		max-width: 800px;
		margin: 0 auto 3.5rem;
		line-height: 1.8;
		text-align: center;
	}

	@media (max-width: 768px) {
		.hero-subtitle {
			text-align: justify;
			text-justify: inter-character;
			font-size: 1rem;
			padding: 0 1rem;
		}
	}

	.hero-actions {
		display: flex;
		gap: 1.25rem;
		justify-content: center;
	}

	/* Stepper V2: Integrated Numbers */
	.how-it-works {
		margin: 10rem auto;
		max-width: 800px;
	}

	.section-title {
		text-align: center;
		margin-bottom: 5rem;
		font-size: 2.5rem;
		color: var(--color-cream);
	}

	.stepper-v2 {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.step-card-v2 {
		background: var(--color-bg-alt);
		border-radius: 24px;
		border: 1px solid var(--glass-border);
		overflow: hidden;
		transition: all 0.3s ease;
	}

	.step-card-v2:hover {
		border-color: var(--color-gold-muted);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
	}

	.step-header-v2 {
		padding: 2rem 2.5rem;
		background: rgba(255, 255, 255, 0.03);
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.step-num-v2 {
		font-family: 'Outfit', sans-serif;
		font-size: 1.2rem;
		font-weight: 900;
		color: var(--color-gold);
		background: rgba(197, 160, 89, 0.1);
		padding: 0.5rem 1rem;
		border-radius: 12px;
		border: 1px solid rgba(197, 160, 89, 0.2);
	}

	.step-header-v2 h3 {
		font-size: 1.6rem;
		margin: 0;
	}

	.step-header-v2 h3 small {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		margin-left: 0.5rem;
		font-weight: 400;
	}

	.step-body-v2 {
		padding: 2.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.step-body-v2 p {
		color: var(--color-text-muted);
		font-size: 1.1rem;
		margin: 0;
	}

	/* Tab Terminal */
	.tab-terminal {
		background: #000;
		border-radius: 14px;
		overflow: hidden;
		border: 1px solid rgba(197, 160, 89, 0.2);
	}

	.tab-header {
		background: #111;
		display: flex;
		flex-wrap: wrap;
		border-bottom: 1px solid #222;
	}

	.tab-btn {
		background: transparent;
		border: none;
		padding: 0.9rem 1.5rem;
		color: #94a3b8;
		font-family: var(--font-main);
		font-size: 0.9rem;
		font-weight: 700;
		cursor: pointer;
		transition: all 0.3s;
		border-bottom: 3px solid transparent;
		min-height: 44px;
		touch-action: manipulation;
		white-space: nowrap;
	}

	.tab-btn.active {
		color: var(--color-gold);
		border-bottom-color: var(--color-gold);
		background: rgba(197, 160, 89, 0.08);
	}

	.tab-content {
		display: none;
	}

	.tab-content.active {
		display: block;
	}

	.mini-terminal {
		background: #000;
		border-radius: 12px;
		overflow: hidden;
		border: 1px solid rgba(197, 160, 89, 0.15);
	}

	.mt-header {
		background: #0a0a0a;
		padding: 0.7rem 1rem;
		border-bottom: 1px solid #1a1a1a;
	}

	.mt-dots {
		display: flex;
		gap: 7px;
	}

	.mt-dots span {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: #222;
	}

	.mt-body {
		padding: 1.5rem;
		font-family: 'Fira Code', monospace;
		font-size: 1rem;
		color: var(--color-gold);
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		line-height: 1.6;
		display: flex;
		gap: 1rem;
	}

	.mt-prompt { color: var(--color-gold-muted); opacity: 1; }

	/* Features */
	.features { padding: 6rem 0; }
	.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(320px, 100%), 1fr)); gap: 2.5rem; }
	.feature-card { padding: 3rem; background: var(--color-bg-alt); border: 1px solid var(--glass-border); border-radius: 24px; }

	@media (max-width: 768px) {
		.hero { padding: max(6rem, calc(5rem + env(safe-area-inset-top))) 0 3rem; }
		.hero-title { font-size: 1.8rem; line-height: 1.4; gap: 0.5rem; }
		.hero-actions { flex-direction: column; gap: 1rem; padding: 0 1.5rem; }

		.section-title { font-size: 1.8rem; margin-bottom: 3rem; }
		.how-it-works { margin: 6rem auto; }
		.step-header-v2 { padding: 1.5rem; gap: 1rem; }
		.step-header-v2 h3 { font-size: 1.3rem; }
		.step-num-v2 { padding: 0.4rem 0.75rem; font-size: 1rem; }
		.step-body-v2 { padding: 1.5rem; }
		.step-body-v2 p { font-size: 1rem; }

		.tab-btn { padding: 0.75rem 1rem; font-size: 0.82rem; flex: 1; }
		.mt-body { padding: 1.25rem; font-size: 0.9rem; }

		.feature-card { padding: 1.75rem; border-radius: 16px; }
		.grid { grid-template-columns: 1fr; }
	}

	/* Terminal Preview */
	.code-preview { margin-bottom: 10rem; }
	.terminal { background: #000; border-radius: 16px; overflow: hidden; border: 1px solid var(--glass-border); box-shadow: 0 40px 80px rgba(0, 0, 0, 0.6); }
	.terminal-header { background: #1a1a1a; padding: 0.8rem 1.2rem; display: flex; align-items: center; gap: 0.6rem; }
	.dot { width: 13px; height: 13px; border-radius: 50%; }
	.red { background: #ff5f56; }
	.yellow { background: #ffbd2e; }
	.green { background: #27c93f; }
	.terminal-body { padding: 2.5rem; font-family: 'Fira Code', monospace; font-size: 1.05rem; line-height: 1.7; overflow-x: auto; -webkit-overflow-scrolling: touch; }
	.prompt { color: var(--color-gold); margin-right: 1rem; }
	.cmd { color: var(--color-cream); }
	.out { color: #94a3b8; }

	@media (max-width: 768px) {
		.terminal-body { padding: 1.5rem; font-size: 0.85rem; }
		.code-preview { margin-bottom: 6rem; }
	}
</style>
