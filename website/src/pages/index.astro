---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Hardware-Bound, Zero-Trace Secret Manager">
	<section class="hero">
		<div class="container hero-content fade-in">
			<div class="logo-container">
				<img src="/logo.jpg" alt="Amulet Logo" class="hero-logo" />
				<div class="logo-glow"></div>
			</div>
			<h1 class="hero-title">
				<span class="line">Protect Your Secrets</span>
				<span class="line">from AI & Accidental Leaks</span>
			</h1>
			<p class="hero-subtitle">
				Amulet is a hardware-bound secret manager designed for solo
				developers and AI-assisted workflows. No more .env files. No
				more accidental commits. Structurally secure.
			</p>
			<div class="hero-actions">
				<a href="/concepts" class="btn btn-primary">Get Started</a>
				<a
					href="https://github.com/tsukasa-art/amulet"
					class="btn btn-outline">View on GitHub</a
				>
			</div>
		</div>
	</section>

	<section class="how-it-works container">
		<h2 class="section-title">Get Started in 3 Steps</h2>
		<div class="stepper-v2">
			<!-- Step 1: Install -->
			<div class="step-card-v2">
				<div class="step-header-v2">
					<span class="step-num-v2">01</span>
					<h3>Install</h3>
				</div>
				<div class="step-body-v2">
					<p>
						Install the CLI tool via your favorite package manager
						for your OS.
					</p>

					<div class="tab-terminal">
						<div class="tab-header">
							<button class="tab-btn active" data-tab="mac-en"
								>macOS</button
							>
							<button class="tab-btn" data-tab="win-en"
								>Windows</button
							>
							<button class="tab-btn" data-tab="linux-en"
								>Linux / Other</button
							>
						</div>
						<div class="tab-body-container">
							<div class="tab-content active" id="tab-mac-en">
								<div class="mini-terminal">
									<div class="mt-body">
										<span class="mt-prompt">$</span>
										<code
											>brew tap tsukasa-art/amulet && brew
											install amulet</code>
									</div>
								</div>
							</div>
							<div class="tab-content" id="tab-win-en">
								<div class="mini-terminal">
									<div class="mt-body">
										<span class="mt-prompt">PS></span>
										<code
											>scoop bucket add amulet
											https://github.com/tsukasa-art/scoop-amulet.git
											&& scoop install amulet</code>
									</div>
								</div>
							</div>
							<div class="tab-content" id="tab-linux-en">
								<div class="mini-terminal">
									<div class="mt-body">
										<span class="mt-prompt">$</span>
										<code
											>curl -fsSL
											https://amulet.pages.dev/install.sh
											| sh</code>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Step 2: Seal -->
			<div class="step-card-v2">
				<div class="step-header-v2">
					<span class="step-num-v2">02</span>
					<h3>Seal <small>(Encrypt & Save)</small></h3>
				</div>
				<div class="step-body-v2">
					<p>
						Securely encrypt your secret and bind it to your machine
						identifier.
					</p>

					<div class="tab-terminal">
						<div class="tab-header">
							<button
								class="tab-btn active"
								data-tab="mac-seal-en">macOS / Linux</button
							>
							<button class="tab-btn" data-tab="win-seal-en"
								>Windows (PS)</button
							>
						</div>
						<div class="tab-body-container">
							<div
								class="tab-content active"
								id="tab-mac-seal-en"
							>
								<div class="mini-terminal">
									<div class="mt-body">
										<span class="mt-prompt">$</span>
										<code
											>echo -n "secret" | amulet seal
											OPENAI_KEY</code>
									</div>
								</div>
							</div>
							<div class="tab-content" id="tab-win-seal-en">
								<div class="mini-terminal">
									<div class="mt-body">
										<span class="mt-prompt">PS></span>
										<code
											>"secret" | amulet seal OPENAI_KEY</code>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Step 3: Use -->
			<div class="step-card-v2">
				<div class="step-header-v2">
					<span class="step-num-v2">03</span>
					<h3>Use <small>(Retrieve Safely)</small></h3>
				</div>
				<div class="step-body-v2">
					<p>
						Unseal your secrets in your code via the SDK or CLI. No
						traces on disk.
					</p>

					<div class="tab-terminal">
						<div class="tab-header">
							<button class="tab-btn active" data-tab="mac-use-en"
								>macOS / Linux</button
							>
							<button class="tab-btn" data-tab="win-use-en"
								>Windows</button
							>
						</div>
						<div class="tab-body-container">
							<div class="tab-content active" id="tab-mac-use-en">
								<div class="mini-terminal">
									<div class="mt-body">
										<span class="mt-prompt">$</span>
										<code>amulet unseal OPENAI_KEY</code>
									</div>
								</div>
							</div>
							<div class="tab-content" id="tab-win-use-en">
								<div class="mini-terminal">
									<div class="mt-body">
										<span class="mt-prompt">PS></span>
										<code>amulet unseal OPENAI_KEY</code>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="features container">
		<div class="grid">
			<div class="feature-card">
				<div class="feature-icon">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="32"
						height="32"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><rect width="18" height="11" x="3" y="11" rx="2" ry="2"
						></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
					>
				</div>
				<h3>Hardware Binding</h3>
				<p>
					Secrets are encrypted and bound to your OS machine
					identifier. They only work on the machine they were sealed
					on.
				</p>
			</div>
			<div class="feature-card">
				<div class="feature-icon">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="32"
						height="32"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path
							d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"
						></path><path
							d="M12 12.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z"
						></path><path d="M12 7v1"></path><path d="M12 16v1"
						></path><path d="M16 12h-1"></path><path d="M9 12H8"
						></path></svg
					>
				</div>
				<h3>AI-Safe Design</h3>
				<p>
					By reading from stdin, it structurally prevents AI coding
					assistants from seeing your secret values in command
					arguments.
				</p>
			</div>
			<div class="feature-card">
				<div class="feature-icon">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="32"
						height="32"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path
							d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"
						></path><path
							d="M4 12c-1.1 0-2-.9-2-2V7c0-1.1.9-2 2-2h16c1.1 0 2 .9 2 2v3c0 1.1-.9 2-2 2"
						></path><path
							d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7"
						></path><path d="M9 17h6"></path></svg
					>
				</div>
				<h3>Zero Trace</h3>
				<p>
					No server dependencies. Works fully locally. Ensures maximum
					privacy and offline availability for your workflow.
				</p>
			</div>
		</div>
	</section>

	<section class="code-preview container">
		<div class="terminal">
			<div class="terminal-header">
				<div class="dot red"></div>
				<div class="dot yellow"></div>
				<div class="dot green"></div>
				<span class="terminal-title">bash</span>
			</div>
			<div class="terminal-body">
				<div class="line">
					<span class="cmd"># Store a secret</span>
				</div>
				<div class="line">
					<span class="prompt">$</span>
					<span class="cmd"
						>echo -n "sk-..." | amulet seal OPENAI_KEY --file
						secrets.vault</span>
				</div>
				<div class="line">
					<span class="out">Passphrase: ***********</span>
				</div>
				<div class="line"></div>
				<div class="line">
					<span class="cmd"># Use in code (Node.js)</span>
				</div>
				<div class="line">
					<span class="prompt">$</span>
					<span class="cmd"
						>amulet unseal OPENAI_KEY --file secrets.vault</span>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script is:inline>
	function setupTabs() {
		const tabs = document.querySelectorAll(".tab-btn");

		tabs.forEach((tab) => {
			tab.addEventListener("click", (e) => {
				e.preventDefault();
				const target = tab.getAttribute("data-tab");
				const container = tab.closest(".tab-terminal");
				if (!container) return;

				container
					.querySelectorAll(".tab-btn")
					.forEach((t) => t.classList.remove("active"));
				container
					.querySelectorAll(".tab-content")
					.forEach((c) => c.classList.remove("active"));

				tab.classList.add("active");
				const content = document.getElementById(`tab-${target}`);
				if (content) {
					content.classList.add("active");
				}
			});
		});
	}
	setupTabs();
	document.addEventListener("astro:page-load", setupTabs);
</script>

<style>
	/* Consisten styling with Japanese version */
	.hero {
		padding: 8rem 0 5rem;
		text-align: center;
		position: relative;
	}

	.logo-container {
		position: relative;
		display: inline-block;
		margin-bottom: 3rem;
	}

	.hero-logo {
		width: 440px;
		max-width: 85vw;
		height: auto;
		border-radius: 16px;
		position: relative;
		z-index: 2;
		box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
		border: 1px solid var(--glass-border);
	}

	.logo-glow {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 110%;
		height: 110%;
		background: radial-gradient(
			circle,
			var(--color-gold) 0%,
			transparent 70%
		);
		opacity: 0.15;
		filter: blur(40px);
		z-index: 1;
	}

	.hero-title {
		font-size: clamp(2.5rem, 8vw, 4rem);
		line-height: 1.2;
		margin-bottom: 2.5rem;
		font-family: "Outfit", sans-serif;
		background: linear-gradient(to bottom, var(--color-cream), #cbd5e1);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		max-width: 900px;
		margin-left: auto;
		margin-right: auto;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.hero-title .line {
		display: block;
	}

	.hero-subtitle {
		font-size: 1.2rem;
		color: var(--color-text-muted);
		max-width: 850px;
		margin: 0 auto 3.5rem;
		line-height: 1.7;
		text-align: center;
	}

	@media (max-width: 768px) {
		.hero-subtitle {
			text-align: center;
			font-size: 1.05rem;
			padding: 0 1.5rem;
			line-height: 1.6;
			max-width: 100%;
		}
	}

	.hero-actions {
		display: flex;
		gap: 1.25rem;
		justify-content: center;
	}

	/* Stepper V2: Integrated Numbers */
	.how-it-works {
		margin: 10rem auto;
		max-width: 800px;
	}

	.section-title {
		text-align: center;
		margin-bottom: 5rem;
		font-size: 2.5rem;
		color: var(--color-cream);
	}

	.stepper-v2 {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.step-card-v2 {
		background: var(--color-bg-alt);
		border-radius: 24px;
		border: 1px solid var(--glass-border);
		overflow: hidden;
		transition: all 0.3s ease;
	}

	.step-card-v2:hover {
		border-color: var(--color-gold-muted);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
	}

	.step-header-v2 {
		padding: 2rem 2.5rem;
		background: rgba(255, 255, 255, 0.03);
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.step-num-v2 {
		font-family: "Outfit", sans-serif;
		font-size: 1.2rem;
		font-weight: 900;
		color: var(--color-gold);
		background: rgba(197, 160, 89, 0.1);
		padding: 0.5rem 1rem;
		border-radius: 12px;
		border: 1px solid rgba(197, 160, 89, 0.2);
	}

	.step-header-v2 h3 {
		font-size: 1.6rem;
		margin: 0;
	}

	.step-header-v2 h3 small {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		margin-left: 0.5rem;
		font-weight: 400;
	}

	.step-body-v2 {
		padding: 2.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.step-body-v2 p {
		color: var(--color-text-muted);
		font-size: 1.1rem;
		margin: 0;
	}

	/* Tab Terminal */
	.tab-terminal {
		background: #000;
		border-radius: 14px;
		overflow: hidden;
		border: 1px solid rgba(197, 160, 89, 0.2);
	}

	.tab-header {
		background: #111;
		display: flex;
		flex-wrap: wrap;
		border-bottom: 1px solid #222;
	}

	.tab-btn {
		background: transparent;
		border: none;
		padding: 0.9rem 1.5rem;
		color: #94a3b8;
		font-family: var(--font-main);
		font-size: 0.9rem;
		font-weight: 700;
		cursor: pointer;
		transition: all 0.3s;
		border-bottom: 3px solid transparent;
		min-height: 44px;
		touch-action: manipulation;
		white-space: nowrap;
	}

	.tab-btn.active {
		color: var(--color-gold);
		border-bottom-color: var(--color-gold);
		background: rgba(197, 160, 89, 0.08);
	}

	.tab-content {
		display: none;
	}

	.tab-content.active {
		display: block;
	}

	.mini-terminal {
		background: #000;
		border-radius: 12px;
		overflow: hidden;
		border: 1px solid rgba(197, 160, 89, 0.15);
	}

	.mt-header {
		background: #0a0a0a;
		padding: 0.7rem 1rem;
		border-bottom: 1px solid #1a1a1a;
	}

	.mt-dots {
		display: flex;
		gap: 7px;
	}

	.mt-dots span {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: #222;
	}

	.mt-body {
		padding: 1.5rem;
		font-family: "Fira Code", monospace;
		font-size: 1rem;
		color: var(--color-gold);
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		line-height: 1.6;
		display: flex;
		gap: 1rem;
	}

	.mt-prompt {
		color: var(--color-gold-muted);
		opacity: 1;
	}

	/* Features */
	.features {
		padding: 6rem 0;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(320px, 100%), 1fr));
		gap: 2.5rem;
	}
	.feature-card {
		padding: 3rem;
		background: var(--color-bg-alt);
		border: 1px solid var(--glass-border);
		border-radius: 24px;
	}

	@media (max-width: 768px) {
		.hero {
			padding: max(6rem, calc(5rem + env(safe-area-inset-top))) 0 3rem;
		}
		.hero-title {
			font-size: 1.8rem;
			line-height: 1.3;
			gap: 0.4rem;
		}
		.hero-actions {
			flex-direction: column;
			gap: 1rem;
			padding: 0 1.5rem;
		}

		.section-title {
			font-size: 1.8rem;
			margin-bottom: 3rem;
		}
		.how-it-works {
			margin: 6rem auto;
		}
		.step-header-v2 {
			padding: 1.5rem;
			gap: 1rem;
		}
		.step-header-v2 h3 {
			font-size: 1.3rem;
		}
		.step-num-v2 {
			padding: 0.4rem 0.75rem;
			font-size: 1rem;
		}
		.step-body-v2 {
			padding: 1.5rem;
		}
		.step-body-v2 p {
			font-size: 1rem;
		}

		.tab-btn {
			padding: 0.75rem 1rem;
			font-size: 0.82rem;
			flex: 1;
		}
		.mt-body {
			padding: 1.25rem;
			font-size: 0.9rem;
		}

		.feature-card {
			padding: 1.75rem;
			border-radius: 16px;
		}
		.grid {
			grid-template-columns: 1fr;
		}
	}

	/* Terminal Preview */
	.code-preview {
		margin-bottom: 10rem;
	}
	.terminal {
		background: #000;
		border-radius: 16px;
		overflow: hidden;
		border: 1px solid var(--glass-border);
		box-shadow: 0 40px 80px rgba(0, 0, 0, 0.6);
	}
	.terminal-header {
		background: #1a1a1a;
		padding: 0.8rem 1.2rem;
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}
	.dot {
		width: 13px;
		height: 13px;
		border-radius: 50%;
	}
	.red {
		background: #ff5f56;
	}
	.yellow {
		background: #ffbd2e;
	}
	.green {
		background: #27c93f;
	}
	.terminal-body {
		padding: 2.5rem;
		font-family: "Fira Code", monospace;
		font-size: 1.05rem;
		line-height: 1.7;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}
	.prompt {
		color: var(--color-gold);
		margin-right: 1rem;
	}
	.cmd {
		color: var(--color-cream);
	}
	.out {
		color: #94a3b8;
	}

	@media (max-width: 768px) {
		.terminal-body {
			padding: 1.5rem;
			font-size: 0.85rem;
		}
		.code-preview {
			margin-bottom: 6rem;
		}
	}
</style>
